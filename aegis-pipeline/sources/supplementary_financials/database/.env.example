# Aegis financial supplement database pipeline environment example.
# Copy this file to database/.env and replace placeholder values locally.
# Do not commit database/.env or any file containing real secrets.

# LLM endpoint.
# LLM_ENDPOINT_MODE: default uses LLM_DEFAULT_URL; internal uses LLM_BASE_URL.
LLM_ENDPOINT_MODE=default
LLM_DEFAULT_URL=https://api.openai.com/v1
LLM_BASE_URL=

# Small model used for startup checks and lightweight stages.
LLM_MODEL_SMALL=gpt-5-mini
LLM_TEMPERATURE_SMALL=
LLM_REASONING_EFFORT_SMALL=low
LLM_MAX_TOKENS_SMALL=4096
LLM_TIMEOUT_SMALL=60
LLM_COST_INPUT_SMALL=
LLM_COST_OUTPUT_SMALL=

# Large model used for extraction/enrichment stages.
LLM_MODEL_LARGE=gpt-5-mini
LLM_TEMPERATURE_LARGE=
LLM_REASONING_EFFORT_LARGE=low
LLM_MAX_TOKENS_LARGE=8192
LLM_TIMEOUT_LARGE=120
LLM_COST_INPUT_LARGE=
LLM_COST_OUTPUT_LARGE=

# Embedding settings used by the current pipeline and Postgres vector schema.
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=100
EMBEDDING_PROGRESS_LOG_INTERVAL_SECONDS=30.0

# Legacy embedding keys retained here only if another local environment expects them.
LLM_EMBEDDING_MODEL=text-embedding-3-large
LLM_EMBEDDING_DIMENSIONS=3072
LLM_EMBEDDING_TIMEOUT=120
LLM_EMBEDDING_COST_INPUT=

# Authentication.
# LLM_AUTH_MODE: default uses OPENAI_API_KEY; oauth uses OAUTH_* settings.
LLM_AUTH_MODE=default
OPENAI_API_KEY=
OAUTH_ENDPOINT=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_GRANT_TYPE=client_credentials

# SSL and logging.
SSL_VERIFY=false
OUTPUT_LOGS=true

# Data source and local/NAS paths.
DATA_SOURCE=financial-supp
INPUT_SOURCE=local
INPUT_BASE_PATH=/Users/alexwday/Projects/aegis-upgrade/aegis-documents/supplementary_financials
OUTPUT_SOURCE=local
OUTPUT_BASE_PATH=

# NAS settings are required only when INPUT_SOURCE or OUTPUT_SOURCE is nas.
NAS_USERNAME=
NAS_PASSWORD=
NAS_SERVER_IP=
NAS_SERVER_NAME=
NAS_SHARE_NAME=
NAS_PORT=445

# PostgreSQL connection.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=public

# Optional master table name stored in master-manifest.json.
# The scripts in scripts/ create/load public."aegis-financial-supp-data" and
# public."aegis-financial-supp-embeddings" directly.
MASTER_DATA_TABLE_NAME=financial_supp_master_data

# Optional enrichment tuning. Defaults in config_setup.py match these values.
DOC_METADATA_CONTEXT_BUDGET=30000
CONTENT_EXTRACTION_BATCH_BUDGET=30000
SECTION_SUMMARY_BATCH_BUDGET=30000
DOC_METADATA_MAX_RETRIES=3
DOC_METADATA_RETRY_DELAY_SECONDS=2.0
CONTENT_EXTRACTION_MAX_RETRIES=3
CONTENT_EXTRACTION_RETRY_DELAY_SECONDS=2.0
SECTION_SUMMARY_MAX_RETRIES=3
SECTION_SUMMARY_RETRY_DELAY_SECONDS=2.0
ENRICHMENT_WORKBOOK_WORKERS=3
ENRICHMENT_SHEET_WORKERS=3
ENRICHMENT_LLM_WORKERS=3
ENRICHMENT_PROGRESS_LOG_INTERVAL_SECONDS=30.0
