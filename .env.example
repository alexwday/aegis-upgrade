# Copy to .env at the repo root, fill local values, then run:
#   python scripts/sync_env.py
#
# Work-computer mode for the OpenAI-compatible endpoint:
#   AUTH_METHOD=oauth
#   LLM_AUTH_MODE=oauth
#   LLM_ENDPOINT_MODE=internal
#   SSL_VERIFY=true

# General
LOG_LEVEL=INFO
ENVIRONMENT=local
OUTPUT_LOGS=true

# Agent auth. AUTH_METHOD is used by aegis-agent.
# Use oauth on the work computer, api_key for direct OpenAI API key auth.
AUTH_METHOD=oauth
API_KEY=

# Pipeline auth. LLM_AUTH_MODE is used by aegis-pipeline.
# Use oauth on the work computer, default for direct OPENAI_API_KEY auth.
LLM_AUTH_MODE=oauth
OPENAI_API_KEY=

# OpenAI-compatible endpoint.
LLM_ENDPOINT_MODE=internal
LLM_DEFAULT_URL=https://api.openai.com/v1
LLM_BASE_URL=

# OAuth client credentials.
OAUTH_ENDPOINT=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_GRANT_TYPE=client_credentials
OAUTH_MAX_RETRIES=3
OAUTH_RETRY_DELAY=1

# SSL.
SSL_VERIFY=true
SSL_CERT_PATH=

# PostgreSQL for the agent.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# PostgreSQL for the pipelines. Leave blank to inherit POSTGRES_* values.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SCHEMA=public

# Agent model tiers.
LLM_MODEL_SMALL=gpt-5-mini
AGENT_LLM_TEMPERATURE_SMALL=0.3
LLM_TEMPERATURE_SMALL=
LLM_MAX_TOKENS_SMALL=1000
LLM_TIMEOUT_SMALL=30
LLM_MAX_RETRIES_SMALL=3
LLM_COST_INPUT_SMALL=0.0001
LLM_COST_OUTPUT_SMALL=0.0002

LLM_MODEL_MEDIUM=gpt-5-mini
AGENT_LLM_TEMPERATURE_MEDIUM=0.5
LLM_TEMPERATURE_MEDIUM=
LLM_MAX_TOKENS_MEDIUM=2000
LLM_TIMEOUT_MEDIUM=60
LLM_MAX_RETRIES_MEDIUM=3
LLM_COST_INPUT_MEDIUM=0.0003
LLM_COST_OUTPUT_MEDIUM=0.0006

LLM_MODEL_LARGE=gpt-5-mini
AGENT_LLM_TEMPERATURE_LARGE=0.7
LLM_TEMPERATURE_LARGE=
LLM_MAX_TOKENS_LARGE=4000
LLM_TIMEOUT_LARGE=120
LLM_MAX_RETRIES_LARGE=3
LLM_COST_INPUT_LARGE=0.0010
LLM_COST_OUTPUT_LARGE=0.0020

# Pipeline chat model options.
LLM_REASONING_EFFORT_SMALL=low
LLM_REASONING_EFFORT_LARGE=low

# Embeddings.
LLM_EMBEDDING_MODEL=text-embedding-3-large
LLM_EMBEDDING_DIMENSIONS=3072
LLM_EMBEDDING_TIMEOUT=120
LLM_EMBEDDING_MAX_RETRIES=3
LLM_EMBEDDING_COST_INPUT=0.00002
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=100
EMBEDDING_PROGRESS_LOG_INTERVAL_SECONDS=30.0

# Local/NAS input and output. sync_env.py writes source-specific local
# INPUT_BASE_PATH values automatically under aegis-documents.
INPUT_SOURCE=local
OUTPUT_SOURCE=local
OUTPUT_BASE_PATH=
NAS_USERNAME=
NAS_PASSWORD=
NAS_SERVER_IP=
NAS_SERVER_NAME=
NAS_SHARE_NAME=
NAS_PORT=445

# Investor slide PDF extraction.
VISION_DPI_SCALE=2.0
EXTRACTION_PAGE_WORKERS=4
PDF_RAW_OCR_MODEL=gpt-5-mini
PDF_RAW_OCR_DETAIL=high
PDF_RAW_OCR_REASONING_EFFORT=low
PDF_RAW_OCR_MAX_OUTPUT_TOKENS=12000
EXTRACTION_REGION_WORKERS=3
PDF_VISION_MAX_RETRIES=3
PDF_VISION_RETRY_DELAY_SECONDS=2.0
PDF_CROP_PADDING=0.025
PDF_BOUNDARY_RETRY_ENABLED=true
PDF_BOUNDARY_RETRY_PADDING=0.075
PDF_BOUNDARY_RETRY_EXTERNAL_LABEL_PADDING=0.14
PDF_BOUNDARY_RETRY_MAX_ATTEMPTS=1
EXTRACTION_PROGRESS_LOG_INTERVAL_SECONDS=30.0

# Enrichment tuning.
DOC_METADATA_CONTEXT_BUDGET=30000
CONTENT_EXTRACTION_BATCH_BUDGET=30000
SECTION_SUMMARY_BATCH_BUDGET=30000
DOC_METADATA_MAX_RETRIES=3
DOC_METADATA_RETRY_DELAY_SECONDS=2.0
CONTENT_EXTRACTION_MAX_RETRIES=3
CONTENT_EXTRACTION_RETRY_DELAY_SECONDS=2.0
SECTION_SUMMARY_MAX_RETRIES=3
SECTION_SUMMARY_RETRY_DELAY_SECONDS=2.0
ENRICHMENT_WORKBOOK_WORKERS=3
ENRICHMENT_SHEET_WORKERS=3
ENRICHMENT_LLM_WORKERS=3
ENRICHMENT_PROGRESS_LOG_INTERVAL_SECONDS=30.0

# Optional report/evidence link base.
S3_REPORTS_BASE_URL=
