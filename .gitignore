.DS_Store
Thumbs.db

# Local secrets and machine-specific config.
.env
*.env
!*.env.example
aegis-agent/.env
aegis-pipeline/sources/*/.env

# Python environments and caches.
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

